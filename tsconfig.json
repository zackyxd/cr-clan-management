{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",
    "sourceMap": true,
    "outDir": "dist",
    "noEmitOnError": true,
    "strict": true,
    "types": ["node", "discord.js"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "src/types"],
  "exclude": [
    "node_modules",
    "dist",
    "src/api/testApiLimiter.ts",
    "src/utils/memberChannelHelpers.examples.ts",
    "__tests__",
    "src/features/stats/statsTemp"
  ]
}
