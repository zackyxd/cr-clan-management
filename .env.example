# Environment Configuration Example
# Copy this file to .env.dev, .env.test, or .env.prod and fill in your values

# ============================================
# Application Environment
# ============================================
NODE_ENV=dev  # Options: dev, test, prod

# ============================================
# Discord Configuration
# ============================================
# Your Discord bot token from https://discord.com/developers/applications
TOKEN=your_discord_bot_token_here

# Your Discord application client ID
CLIENT_ID=your_discord_client_id_here

# Optional: Specific guild/server ID for testing commands
GUILD_ID=your_test_guild_id_here

# ============================================
# PostgreSQL Database Configuration
# ============================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=discord_bot_dev
PGUSER=discord_bot
PGPASSWORD=your_database_password_here

# Alternative: Full connection string (overrides above if set)
# DATABASE_URL=postgresql://discord_bot:password@localhost:5432/discord_bot_dev

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Clash Royale API
# ============================================
# Get your API key from https://developer.clashroyale.com
CR_KEY=your_clash_royale_api_key_here

# ============================================
# Logging Configuration
# ============================================
# Options: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# Notes
# ============================================
# - Never commit .env files to git
# - Use strong passwords for production
# - Keep production credentials secure
# - For local development, you can use the defaults in docker-compose.yml
